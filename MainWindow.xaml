<Window x:Class="Picross.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Picross"
        mc:Ignorable="d"
        Title="Picross Editor" Height="550" Width="1300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="4*"></RowDefinition>
        </Grid.RowDefinitions>

        <Label HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" >Picross Editor </Label>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btn5" Width="50" Height="50" Margin="0 0 20 0" Click="sizeSelection_Click" Content="5x5"></Button>
            <Button x:Name="btn10" Width="50" Height="50" Margin="0 0 20 0" Click="sizeSelection_Click" Content="10x10"></Button>
            <Button x:Name="btn15" Width="50" Height="50" Margin="0 0 20 0" Click="sizeSelection_Click" Content="15x15"></Button>
            <Button x:Name="btn20" Width="50" Height="50" Margin="0 0 20 0" Click="sizeSelection_Click" Content="20x20"></Button>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <StackPanel>
                <Button Grid.Row="0" Width="150" Height="40" Margin="0 0 0 20" Click="clearButton_Click">Clear</Button>
                <Button Grid.Row="0" Width="150" Height="40" Margin="0 0 0 0" Click="generateRandom_Click">Random</Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                <Button Width="150" Height="40" Margin="0 0 0 20" Click="openFile_Click">Open</Button>
                <Button Width="150" Height="40" Margin="0 0 0 20" Click="saveFile_Click">Save</Button>
            </StackPanel>
        </Grid>

            <Grid x:Name="game" Grid.Column="1" Grid.Row="1">
                
            </Grid>
    </Grid>
</Window>
